{
  "extends": "@repo/typescript-config/node.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "module": "preserve",
    "moduleResolution": "bundler",
    "paths": {
      "#routes/*": ["./src/routes/*"],
      "#middleware/*": ["./src/middleware/*"]
    }
  },
  "include": ["src"]
}
